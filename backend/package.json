{
  "name": "e-shop",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:prod": "cross-env NODE_ENV=production tsx src/db/migrate.ts",
    "push": "drizzle-kit push"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1060.0",
    "@hono/node-server": "^1.19.14",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "nanoid": "^5.0.7",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}