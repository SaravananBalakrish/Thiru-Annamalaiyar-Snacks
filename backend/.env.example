# =============================================================================
# e-Shop Backend Environment Configuration
# =============================================================================
# Copy this file to .env for development
# Copy this file to .env.production for production
# NEVER commit .env or .env.production files with real credentials
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For local development with PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# For Neon DB (serverless PostgreSQL) in production
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Direct connection URL (for migrations only, not for pooler connections)
# In production with Neon, this must be the direct (non-pooler) connection string
DATABASE_DIRECT_URL=postgresql://username:password@localhost:5432/database_name

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-minimum-32-characters

# -----------------------------------------------------------------------------
# Client URL (for CORS)
# -----------------------------------------------------------------------------
CLIENT_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# AWS S3 Configuration (for file uploads)
# -----------------------------------------------------------------------------
AWS_REGION=your-aws-region
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET=your-s3-bucket-name

# -----------------------------------------------------------------------------
# Twilio Configuration (for SMS OTP)
# -----------------------------------------------------------------------------
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# UPI Payment Configuration
# -----------------------------------------------------------------------------
UPI_ID=your-upi-id@bank

# -----------------------------------------------------------------------------
# Redis Configuration (for OTP storage in production)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Database Pool Configuration (optional, for production)
# -----------------------------------------------------------------------------
DB_POOL_MAX=20
DB_POOL_MIN=4
